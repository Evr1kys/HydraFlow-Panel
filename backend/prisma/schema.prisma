generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  uuid         String    @unique @default(uuid())
  subToken     String    @unique @default(uuid()) @map("sub_token")
  enabled      Boolean   @default(true)
  trafficUp    BigInt    @default(0) @map("traffic_up")
  trafficDown  BigInt    @default(0) @map("traffic_down")
  trafficLimit BigInt?   @map("traffic_limit")
  expiryDate   DateTime? @map("expiry_date")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

model Admin {
  id       String @id @default(uuid())
  email    String @unique
  password String

  @@map("admins")
}

model Settings {
  id                String  @id @default("main")
  serverIp          String? @map("server_ip")
  realityPort       Int     @default(443) @map("reality_port")
  realitySni        String  @default("www.apple.com") @map("reality_sni")
  realityPublicKey  String? @map("reality_public_key")
  realityPrivateKey String? @map("reality_private_key")
  realityShortId    String? @map("reality_short_id")
  wsPort            Int     @default(2053) @map("ws_port")
  wsPath            String? @map("ws_path")
  ssPort            Int     @default(8388) @map("ss_port")
  ssPassword        String? @map("ss_password")

  @@map("settings")
}
