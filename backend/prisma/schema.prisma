datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Admin {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  totpSecret    String?
  totpEnabled   Boolean        @default(false)
  role          String         @default("admin") // superadmin | admin | operator | readonly
  enabled       Boolean        @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime       @default(now())
  sessions      Session[]
  passkeys      Passkey[]
  oauthAccounts OAuthAccount[]
  auditLogs     AuditLog[]
  apiKeys       ApiKey[]
}

model Passkey {
  id           String   @id @default(uuid())
  adminId      String
  credentialId String   @unique
  publicKey    Bytes
  counter      Int      @default(0)
  transports   String[]
  createdAt    DateTime @default(now())
  admin        Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
}

model OAuthAccount {
  id         String   @id @default(uuid())
  adminId    String
  provider   String
  providerId String
  email      String?
  createdAt  DateTime @default(now())
  admin      Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
}

model User {
  id                  String          @id @default(uuid())
  email               String          @unique
  uuid                String          @unique @default(uuid())
  subToken            String          @unique @default(uuid())
  shortUuid           String?         @unique
  tag                 String?
  tId                 BigInt          @default(autoincrement())
  enabled             Boolean         @default(true)
  trafficUp           BigInt          @default(0)
  trafficDown         BigInt          @default(0)
  trafficLimit        BigInt?
  lifetimeTrafficUsed BigInt          @default(0)
  trafficStrategy     String          @default("NO_RESET")
  lastTrafficResetAt  DateTime?
  expiryDate          DateTime?
  maxDevices          Int             @default(3)
  hwidDeviceLimit     Int?
  onlineAt            DateTime?
  remark              String?
  telegramId          BigInt?
  botUserId           String?         @unique
  internalSquadId     String?
  internalSquad       InternalSquad?  @relation(fields: [internalSquadId], references: [id], onDelete: SetNull)
  externalSquadId     String?
  externalSquad       ExternalSquad?  @relation(fields: [externalSquadId], references: [id], onDelete: SetNull)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  activeSessions      ActiveSession[]
  trafficHistory      UserTraffic[]
  devices             HwidDevice[]
  metadata            UserMeta[]
  subRequests         SubscriptionRequest[]

  @@index([tId])
  @@index([tag])
}

model SubscriptionRequest {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ip           String
  userAgent    String?
  platform     String?  // ios | android | windows | macos | linux | unknown
  format       String?  // v2ray | clash | singbox | outline
  status       Int      // HTTP status code
  responseSize Int?
  createdAt    DateTime @default(now())
  @@index([userId, createdAt])
}

model Settings {
  id              String  @id @default("main")
  serverIp        String?

  realityEnabled  Boolean @default(true)
  realityPort     Int     @default(443)
  realitySni      String  @default("www.apple.com")
  realityPbk      String?
  realityPvk      String?
  realitySid      String?

  wsEnabled       Boolean @default(true)
  wsPort          Int     @default(2053)
  wsPath          String?
  wsHost          String?

  ssEnabled       Boolean @default(false)
  ssPort          Int     @default(8388)
  ssMethod        String  @default("2022-blake3-aes-256-gcm")
  ssPassword      String?

  cdnDomain       String?
  splitTunneling  Boolean @default(true)
  adBlocking      Boolean @default(true)
}

model ISPReport {
  id        String   @id @default(uuid())
  country   String
  isp       String
  asn       Int?
  protocol  String
  status    String
  createdAt DateTime @default(now())
}

model Alert {
  id        String   @id @default(uuid())
  isp       String
  protocol  String
  oldStatus String
  newStatus String
  country   String
  createdAt DateTime @default(now())
}

model Node {
  id             String          @id @default(uuid())
  name           String
  address        String
  port           Int
  apiKey         String          @default("")
  enabled        Boolean         @default(true)
  status         String          @default("unknown")
  lastCheck      DateTime?
  createdAt      DateTime        @default(now())
  billingNodes   BillingNode[]
  plugins        NodePlugin[]
  activeSessions ActiveSession[]
  metadata       NodeMeta[]
}

model Webhook {
  id        String   @id @default(uuid())
  url       String
  events    String[]
  secret    String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
}

model BillingProvider {
  id          String        @id @default(uuid())
  name        String
  apiUrl      String        @default("")
  credentials String        @default("")
  createdAt   DateTime      @default(now())
  nodes       BillingNode[]
}

model BillingNode {
  id          String          @id @default(uuid())
  nodeId      String
  providerId  String
  monthlyRate Float           @default(0)
  currency    String          @default("USD")
  renewalDate DateTime?
  node        Node            @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  provider    BillingProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  history     BillingHistory[]
  createdAt   DateTime        @default(now())
}

model BillingHistory {
  id            String      @id @default(uuid())
  billingNodeId String
  amount        Float
  currency      String      @default("USD")
  date          DateTime    @default(now())
  paid          Boolean     @default(false)
  billingNode   BillingNode @relation(fields: [billingNodeId], references: [id], onDelete: Cascade)
}

model NodePlugin {
  id      String  @id @default(uuid())
  nodeId  String
  type    String
  config  String  @default("{}")
  enabled Boolean @default(true)
  node    Node    @relation(fields: [nodeId], references: [id], onDelete: Cascade)
}

model ActiveSession {
  id         String   @id @default(uuid())
  userId     String
  nodeId     String?
  protocol   String
  clientIp   String
  startedAt  DateTime @default(now())
  bytesUp    BigInt   @default(0)
  bytesDown  BigInt   @default(0)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  node       Node?    @relation(fields: [nodeId], references: [id], onDelete: SetNull)
}

model UserTraffic {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  upload    BigInt   @default(0)
  download  BigInt   @default(0)
  period    String   // "hourly", "daily", "monthly"
  date      DateTime
  createdAt DateTime @default(now())
  @@index([userId, period, date])
}

model Session {
  id        String   @id @default(uuid())
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id])
  token     String   @unique
  userAgent String?
  ip        String?
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model ConfigProfile {
  id        String   @id @default(uuid())
  name      String
  config    String   // JSON xray config template
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HwidDevice {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hwid      String
  platform  String?  // "android", "ios", "windows", "macos"
  lastSeen  DateTime @default(now())
  createdAt DateTime @default(now())
  @@unique([userId, hwid])
  @@index([userId])
}

model InternalSquad {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  nodeIds     String[]
  createdAt   DateTime @default(now())
  users       User[]
}

model ExternalSquad {
  id            String   @id @default(uuid())
  name          String   @unique
  apiKey        String   @unique @default(uuid())
  maxUsers      Int      @default(100)
  hostOverrides Json?
  enabled       Boolean  @default(true)
  subPageTitle  String?
  subPageBrand  String?
  createdAt     DateTime @default(now())
  users         User[]
}

model AuditLog {
  id         String   @id @default(uuid())
  adminId    String?
  admin      Admin?   @relation(fields: [adminId], references: [id], onDelete: SetNull)
  action     String   // user.create, user.delete, settings.update, etc.
  resource   String   // users | nodes | settings | squads | ...
  resourceId String?
  payload    Json?
  ip         String?
  userAgent  String?
  success    Boolean  @default(true)
  errorMsg   String?
  createdAt  DateTime @default(now())
  @@index([adminId, createdAt])
  @@index([resource, resourceId])
  @@index([action, createdAt])
}

model ApiKey {
  id         String    @id @default(uuid())
  adminId    String
  admin      Admin     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  name       String
  keyHash    String    @unique
  keyPrefix  String    // first 8 chars for display
  scopes     String[]  @default([]) // users:read, users:write, nodes:read, ...
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revoked    Boolean   @default(false)
  createdAt  DateTime  @default(now())
  @@index([adminId])
  @@index([keyHash])
}

model BackupJob {
  id         String    @id @default(uuid())
  type       String    // manual | scheduled
  status     String    @default("pending") // pending | running | completed | failed
  filePath   String?
  fileSize   BigInt?
  errorMsg   String?
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  @@index([status, startedAt])
}

model EmailSettings {
  id         String  @id @default("main")
  enabled    Boolean @default(false)
  smtpHost   String?
  smtpPort   Int     @default(587)
  smtpUser   String?
  smtpPass   String?
  smtpSecure Boolean @default(true)
  fromEmail  String?
  fromName   String  @default("HydraFlow")
  updatedAt  DateTime @updatedAt
}

model UserSubscription {
  id             String    @id @default(uuid())
  userId         String
  plan           String    // monthly | yearly | custom
  priceAmount    Float
  priceCurrency  String    @default("USD")
  provider       String    // yookassa | stripe | crypto | manual
  externalId     String?   // provider's payment/subscription id
  status         String    @default("pending") // pending | active | cancelled | expired
  trafficGb      Int?
  daysDuration   Int
  startDate      DateTime  @default(now())
  endDate        DateTime?
  cancelledAt    DateTime?
  autoRenew      Boolean   @default(false)
  createdAt      DateTime  @default(now())
  @@index([userId])
  @@index([status, endDate])
}

model WebhookDelivery {
  id          String    @id @default(uuid())
  webhookId   String
  event       String
  payload     Json
  status      String    @default("pending") // pending | success | failed | dead
  attempts    Int       @default(0)
  lastError   String?
  nextRetryAt DateTime?
  deliveredAt DateTime?
  createdAt   DateTime  @default(now())
  @@index([status, nextRetryAt])
  @@index([webhookId, createdAt])
}

model BotUser {
  id           String           @id @default(uuid())
  telegramId   BigInt           @unique
  username     String?
  firstName    String?
  languageCode String           @default("ru")
  balance      Decimal          @default(0) @db.Decimal(10, 2)
  totalSpent   Decimal          @default(0) @db.Decimal(10, 2)
  referredBy   String?
  banned       Boolean          @default(false)
  userId       String?
  createdAt    DateTime         @default(now())
  lastSeenAt   DateTime         @default(now())
  transactions BotTransaction[]
  tickets      SupportTicket[]

  @@index([telegramId])
}

model BotButton {
  id             String   @id @default(uuid())
  menuType       String
  buttonId       String
  text           String
  callbackData   String?
  url            String?
  rowPosition    Int      @default(0)
  columnPosition Int      @default(0)
  buttonWidth    Int      @default(1)
  sortOrder      Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([menuType, buttonId])
  @@index([menuType, sortOrder])
}

model BotMenuConfig {
  menuType     String   @id
  keyboardMode String   @default("inline") // inline | reply
  resize       Boolean  @default(true)
  oneTime      Boolean  @default(false)
  title        String?
  updatedAt    DateTime @updatedAt
}

model BotPlan {
  id           String   @id @default(uuid())
  name         String
  daysDuration Int
  trafficGb    Int?
  price        Decimal  @db.Decimal(10, 2)
  currency     String   @default("RUB")
  enabled      Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
}

model BotTransaction {
  id                String    @id @default(uuid())
  botUserId         String
  botUser           BotUser   @relation(fields: [botUserId], references: [id])
  type              String
  amount            Decimal   @db.Decimal(10, 2)
  currency          String    @default("RUB")
  provider          String
  providerPaymentId String?
  status            String    @default("pending")
  planId            String?
  promoCode         String?
  createdAt         DateTime  @default(now())
  completedAt       DateTime?

  @@index([botUserId, createdAt])
  @@index([status])
}

model BotPromoCode {
  id              String    @id @default(uuid())
  code            String    @unique
  discountPercent Int?
  discountAmount  Decimal?  @db.Decimal(10, 2)
  maxUses         Int?
  usedCount       Int       @default(0)
  validFrom       DateTime  @default(now())
  validUntil      DateTime?
  enabled         Boolean   @default(true)
  createdAt       DateTime  @default(now())
}

model SupportTicket {
  id        String           @id @default(uuid())
  botUserId String
  botUser   BotUser          @relation(fields: [botUserId], references: [id])
  subject   String
  status    String           @default("open")
  messages  SupportMessage[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([status])
}

model SupportMessage {
  id        String        @id @default(uuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  fromAdmin Boolean       @default(false)
  text      String
  createdAt DateTime      @default(now())
}

model BotSetting {
  key   String @id
  value String
}

model UserMeta {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([userId, key])
  @@index([userId])
}

model NodeMeta {
  id        String   @id @default(uuid())
  nodeId    String
  node      Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([nodeId, key])
  @@index([nodeId])
}
