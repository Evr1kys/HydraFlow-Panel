# ─── Core ─────────────────────────────────────────────────────────
DB_PASSWORD=change-me-strong-password
JWT_SECRET=change-me-very-long-random-string-at-least-32-chars
ADMIN_EMAIL=admin@hydraflow.dev
ADMIN_PASSWORD=admin

# Public IP of your proxy server (used in subscription URLs)
SERVER_PUBLIC_IP=

# Public URL of the panel (used for subscription QR codes, payment callbacks, etc.)
PUBLIC_BASE_URL=https://panel.yourdomain.com

# Comma-separated list of allowed frontend origins (CORS)
CORS_ORIGIN=https://panel.yourdomain.com

# ─── Redis (required) ─────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Telegram bot (optional) ──────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_ADMIN_ID=

# Set to true to enable the user-facing shop bot
BOT_SHOP_ENABLED=false
BOT_SHOP_MODE=standalone

# ─── Payment providers (all optional) ─────────────────────────────
# YooKassa (Russian cards / SBP)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Stripe (international cards)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# CryptoBot (Telegram crypto)
CRYPTOBOT_TOKEN=

# Heleket (crypto)
HELEKET_MERCHANT_ID=
HELEKET_API_KEY=
HELEKET_API_BASE=https://api.heleket.com

# NOWPayments (crypto)
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_CALLBACK_URL=

# ─── WebAuthn / Passkeys (optional) ───────────────────────────────
WEBAUTHN_RP_NAME=HydraFlow Panel
WEBAUTHN_RP_ID=panel.yourdomain.com
WEBAUTHN_ORIGIN=https://panel.yourdomain.com

# ─── OAuth providers (optional) ───────────────────────────────────
# Telegram OAuth
TELEGRAM_OAUTH_BOT_TOKEN=
# GitHub OAuth
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# Yandex OAuth
YANDEX_OAUTH_CLIENT_ID=
YANDEX_OAUTH_CLIENT_SECRET=
